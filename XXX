<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ordre des pourfendeurs | Archives Confidentielles</title>
    
    <link rel="icon" type="image/jpeg" href="https://imgur.com/Cl4RqsF.png">

    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght=400;700;900&family=Noto+Sans+JP:wght=300;700&family=Share+Tech+Mono&family=Cormorant+Garamond:ital,wght=1,500;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <style>
        :root {
            --emerald-primary: #00ff66;
            --emerald-dim: #00aa44;
            --emerald-glow: rgba(0, 255, 102, 0.25);
            --dark-base: #0a0d0b;
            --dark-card: #111613;
            --glass: rgba(0, 255, 102, 0.02);
            --border-color: rgba(0, 255, 102, 0.15);
            --transition-smooth: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        html { scroll-behavior: smooth; }
        * { cursor: default; box-sizing: border-box; }

        body {
            color: #d0dcd3;
            font-family: 'Noto Sans JP', sans-serif;
            margin: 0;
            background-color: var(--dark-base);
            overflow-x: hidden;
            letter-spacing: 0.5px;
            -webkit-font-smoothing: antialiased;
        }

        #matrix-particles {
            position: fixed;
            top: 0; left: 0;
            width: 100vw; height: 100vh;
            z-index: 1;
            pointer-events: none;
            opacity: 0.15;
        }

        .vignette {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle, transparent 30%, rgba(0,0,0,0.8) 100%);
            z-index: 2; pointer-events: none;
        }

        header {
            position: fixed; width: 100%; padding: 20px 60px;
            display: flex; justify-content: space-between; align-items: center;
            z-index: 1000;
        }

        .logo-top { 
            height: 70px; 
            filter: drop-shadow(0 0 10px var(--emerald-glow)) grayscale(1) brightness(1.5);
        }

        /* --- LOGIN SCREEN --- */
        #login-screen {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: var(--dark-base); z-index: 9999;
            display: flex; justify-content: center; align-items: center;
            transition: var(--transition-smooth);
        }

        .login-box {
            background: var(--dark-card);
            border: 1px solid var(--emerald-dim);
            padding: 40px; text-align: center;
            max-width: 400px; width: 90%;
            box-shadow: 0 0 30px rgba(0, 255, 102, 0.05);
            backdrop-filter: blur(10px);
        }

        .login-box h2 {
            font-family: 'Cinzel', serif; color: #fff;
            letter-spacing: 3px; margin-bottom: 30px;
        }

        .input-group {
            margin-bottom: 20px; position: relative;
        }

        .input-group input {
            width: 100%; padding: 12px 15px;
            background: rgba(0,0,0,0.5);
            border: 1px solid var(--border-color);
            color: #fff; font-family: 'Share Tech Mono', monospace;
            font-size: 1rem; transition: 0.3s;
        }

        .input-group input:focus {
            outline: none; border-color: var(--emerald-primary);
            box-shadow: 0 0 10px var(--emerald-glow);
        }

        .btn-login {
            width: 100%; padding: 12px;
            background: transparent; border: 1px solid var(--emerald-primary);
            color: var(--emerald-primary); font-family: 'Cinzel', serif;
            font-weight: bold; letter-spacing: 2px; transition: 0.3s;
        }

        .btn-login:hover {
            background: var(--emerald-primary); color: var(--dark-base);
            box-shadow: 0 0 15px var(--emerald-glow);
        }

        #login-error {
            color: #ff3333; font-family: 'Share Tech Mono', monospace;
            font-size: 0.85rem; margin-top: 15px; display: none;
        }

        /* --- MAIN CONTENT --- */
        #main-content {
            display: none; opacity: 0; transition: opacity 1s ease;
        }

        /* --- HERO SECTION --- */
        .hero { 
            position: relative; z-index: 3; height: 60vh; 
            display: flex; flex-direction: column; justify-content: center; align-items: center; 
            text-align: center;
        }

        .mist-title { 
            font-family: 'Cinzel', serif; 
            font-size: clamp(2rem, 6vw, 3.5rem); 
            color: #fff; margin: 0;
            text-shadow: 0 0 20px var(--emerald-glow);
            letter-spacing: 4px;
        }

        .hero-author {
            font-family: 'Share Tech Mono', monospace;
            font-size: 1rem; letter-spacing: 4px;
            color: var(--emerald-primary); margin-top: 15px;
            text-transform: uppercase;
        }

        /* --- TABS SYSTEM --- */
        .clearance-tabs {
            position: relative; z-index: 3;
            display: flex; justify-content: center; gap: 20px;
            margin-bottom: 50px; padding: 0 10%;
        }

        .tab-btn {
            background: var(--dark-card);
            border: 1px solid var(--border-color);
            color: #88998e; padding: 15px 30px;
            font-family: 'Share Tech Mono', monospace;
            font-size: 0.9rem; letter-spacing: 2px;
            transition: var(--transition-smooth);
        }

        .tab-btn:hover, .tab-btn.active {
            border-color: var(--emerald-primary);
            color: var(--emerald-primary);
            box-shadow: 0 0 15px var(--emerald-glow);
        }

        /* --- ARCHIVE ZONES --- */
        .archive-zone {
            display: none; position: relative; z-index: 3; padding: 0 10% 100px 10%;
        }

        .archive-zone.active { display: block; }

        .zone-header {
            font-family: 'Cinzel', serif; color: #fff;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 10px; margin-bottom: 40px;
            letter-spacing: 2px; font-size: 1.5rem;
        }

        .lore-grid { 
            display: flex; flex-wrap: wrap; gap: 30px; justify-content: flex-start;
        }

        .clickable-card {
            background: linear-gradient(145deg, rgba(0,255,102,0.03) 0%, rgba(0,0,0,0.3) 100%);
            border: 1px solid var(--border-color);
            padding: 40px 25px; text-decoration: none; color: inherit;
            transition: var(--transition-smooth); border-radius: 4px;
            text-align: center; backdrop-filter: blur(5px);
            display: flex; flex-direction: column; align-items: center;
            width: 300px;
        }

        .clickable-card:hover {
            transform: translateY(-5px);
            border-color: var(--emerald-primary);
            box-shadow: 0 10px 25px rgba(0,255,102,0.1);
        }

        .logo-spell-grid { 
            width: 100px; height: 100px; border-radius: 50%; margin-bottom: 20px; 
            border: 1px solid var(--emerald-dim); padding: 5px; object-fit: cover;
            filter: grayscale(0.3) sepia(0.2) hue-rotate(80deg);
        }

        .clickable-card h3 { font-family: 'Cinzel', serif; font-size: 1.2rem; letter-spacing: 1px; color: #fff; margin: 10px 0; }
        .clickable-card p { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; color: #a4b3a8; margin: 0; line-height: 1.5; }

        .locked-notice {
            text-align: center; padding: 60px; background: rgba(0,0,0,0.4);
            border: 1px dashed rgba(255,51,51,0.3); color: #ff5555;
            font-family: 'Share Tech Mono', monospace; letter-spacing: 2px;
        }
        .locked-notice i { font-size: 3rem; margin-bottom: 20px; color: #ff3333; }

        /* --- MODAL --- */
        .details-section { 
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
            background: rgba(5, 8, 6, 0.98); z-index: 3000;
            display: none; align-items: flex-start; justify-content: center;
            overflow-y: auto; padding: 60px 20px; opacity: 0; transition: opacity 0.5s ease;
        }
        .details-section:target { display: flex; opacity: 1; }

        .content-box {
            max-width: 900px; background: var(--dark-card);
            padding: 60px; border: 1px solid var(--emerald-dim);
            position: relative; backdrop-filter: blur(20px); margin-bottom: 60px;
            box-shadow: 0 0 40px rgba(0,255,102,0.05);
        }

        .lore-text h4 {
            font-family: 'Cinzel', serif; color: var(--emerald-primary);
            margin: 30px 0 15px 0; border-bottom: 1px solid rgba(0,255,102,0.2);
            display: block; letter-spacing: 2px;
        }

        .lore-text p {
            font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; 
            line-height: 1.7; color: #cbd6ce; text-align: justify; margin-bottom: 18px;
        }

        .info-label { color: var(--emerald-primary); font-weight: bold; font-family: 'Share Tech Mono'; font-size: 0.9rem; }

        .btn-close {
            display: inline-block; padding: 12px 40px; margin-top: 40px;
            border: 1px solid var(--emerald-primary); color: var(--emerald-primary); 
            text-decoration: none; font-family: 'Cinzel', serif; font-size: 0.8rem; letter-spacing: 3px;
            transition: 0.4s;
        }
        .btn-close:hover { background: var(--emerald-primary); color: var(--dark-base); }

    </style>
</head>
<body>

    <canvas id="matrix-particles"></canvas>
    <div class="vignette"></div>

    <div id="login-screen">
        <div class="login-box">
            <h2>ACCÈS SÉCURISÉ</h2>
            <div class="input-group">
                <input type="text" id="username" placeholder="IDENTIFIANT" autocomplete="off">
            </div>
            <div class="input-group">
                <input type="password" id="password" placeholder="MOT DE PASSE">
            </div>
            <button class="btn-login" onclick="checkLogin()">S'AUTHENTIFIER</button>
            <div id="login-error">IDENTIFIANTS INCORRECTS - ACCÈS REFUSÉ</div>
        </div>
    </div>

    <div id="main-content">
        <header id="navbar">
            <img src="https://imgur.com/Cl4RqsF.png" alt="Logo" class="logo-top">
        </header>

        <section id="home" class="hero">
            <h1 class="mist-title" data-aos="zoom-in">ARCHIVES DE L'ORDRE DES POURFENDEURS</h1>
            <div class="hero-author">SYSTÈME DE GESTION DES INFORMATIONS</div>
        </section>

        <div class="clearance-tabs">
            <button class="tab-btn active" onclick="switchLevel(1)">NIVEAU 1 : ACCÈS STANDARD</button>
            <button class="tab-btn" onclick="switchLevel(2)">NIVEAU 2 : RESTREINT</button>
            <button class="tab-btn" onclick="switchLevel(3)">NIVEAU 3 : TOP SECRET</button>
        </div>

        <section id="level-1" class="archive-zone active">
            <div class="zone-header">// DOSSIERS PUBLICS & RAPPORTS DE TERRAIN</div>
            <div class="lore-grid">
                <a href="#details-yuketsu" class="clickable-card" data-aos="fade-up">
                    <img src="https://imgur.com/UgNCxqf.png" class="logo-spell-grid" alt="Ito Yuketsu">
                    <h3>Ito Yuketsu</h3>
                    <p>Rang : Kanoe<br>Respiration : Son<br>Statut : Observé</p>
                </a>
            </div>
        </section>

        <section id="level-2" class="archive-zone">
            <div class="zone-header">// DONNÉES SENSIBLES - ACCÈS COHORTES SUIVANTES</div>
            <div class="lore-grid">
                <div class="locked-notice" style="width: 100%;">
                    <i class="fa-solid fa-folder-open"></i>
                    <p>AUCUNE DONNÉE ENREGISTRÉE POUR LE MOMENT.<br>EN ATTENTE DE COMPTES RENDUS SUPPLÉMENTAIRES.</p>
                </div>
            </div>
        </section>

        <section id="level-3" class="archive-zone">
            <div class="zone-header">// DOSSIERS SUPRÊMES - HAUTE DIRECTION DE L'ORDRE</div>
            <div class="lore-grid">
                <div class="locked-notice" style="width: 100%;">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    <p>ZONE EN ATTENTE D'ALIMENTATION DE DONNÉES CRITIQUES.</p>
                </div>
            </div>
        </section>

        <section id="details-yuketsu" class="details-section">
            <div class="content-box">
                <img src="https://imgur.com/UgNCxqf.png" style="width: 100px; display: block; margin: 0 auto 20px; border-radius: 50%; border: 1px solid var(--emerald-primary); filter: hue-rotate(80deg);">
                <h2 style="text-align: center; font-family: 'Cinzel'; color: #fff; letter-spacing: 5px; margin-bottom: 40px;">ITO YUKETSU</h2>
                
                <div class="lore-text">
                    <p><span class="info-label">CODE IDENTIFIANT :</span> ODP-YUK-012</p>
                    <p><span class="info-label">RANG :</span> Kanoe</p>
                    <p><span class="info-label">RESPIRATION :</span> Souffle du Son</p>
                    <p><span class="info-label">ÂGE :</span> 12 ans</p>
                    
                    <h4>Description Générale</h4>
                    <p>Ito Yuketsu est un jeune pourfendeur vêtu d’un haori blanc et doré. Ses cheveux blonds ainsi que ses yeux d’un doré brillant lui confèrent une apparence particulièrement marquante. Malgré son jeune âge, il dégage une certaine chaleur humaine qui contraste avec l’attitude réservée qu’il adopte lors des premiers contacts.</p>
                    <p>Une fois la méfiance initiale dissipée, le sujet se révèle particulièrement enfantin et sociable. Il apprécie plaisanter avec les autres membres de l'Ordre et semble entretenir des relations globalement positives avec son entourage.</p>
                    
                    <h4>Comportement Observé</h4>
                    <p>Le sujet présente une personnalité énergique et légère. Il manifeste un goût prononcé pour les sucreries, notamment les bonbons au caramel, au point que cela pourrait être considéré comme une forme d’addiction mineure.</p>
                    <p>Malgré cette attitude insouciante, Yuketsu demeure un combattant agile et discipliné lorsqu’il est confronté à des situations sérieuses. Son comportement laisse penser à une volonté sincère de préserver ses proches de la haine et de la souffrance, motivation qui semble profondément liée à son engagement au sein de l'Ordre des pourfendeurs.</p>

                    <h4>Origine & Environnement Familial</h4>
                    <p>Le sujet est issu d’une famille de pourfendeurs ; son père comme sa mère appartiennent ou appartenaient à l'Ordre. D’après les informations récoltées, il ne semble pas avoir réellement eu le choix quant à son intégration dans l’armée.</p>
                    <p>Des rumeurs persistantes entourent toutefois sa mère, décrite comme une femme crainte voire détestée par une partie de son entourage. Cette réputation proviendrait d’un tempérament extrêmement exigeant ainsi que de méthodes d’enseignement jugées peu orthodoxes.</p>

                    <h4>Capacités & Ambitions</h4>
                    <p>Ito Yuketsu maîtrise le Souffle du Son et nourrit l’ambition de devenir le premier Pilier à représenter officiellement cette respiration. Cette combinaison entre ambition martiale et volonté protectrice fait de lui un individu particulièrement prometteur.</p>

                    <h4>Relations Connues</h4>
                    <p>Il a notamment été aperçu à plusieurs reprises en compagnie d’une Tsuchinoto du Souffle du Vent nommée Kokomi Toyama. Les deux individus semblent entretenir une relation amicale solide.</p>
                </div>

                <div style="text-align: center;">
                    <a href="#" class="btn-close">REVENIR AUX ARCHIVES</a>
                </div>
            </div>
        </section>
    </div>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        function checkLogin() {
            const user = document.getElementById('username').value;
            const pass = document.getElementById('password').value;
            const errorMsg = document.getElementById('login-error');
            const loginScreen = document.getElementById('login-screen');
            const mainContent = document.getElementById('main-content');

            if (user === "M-0" && pass === "Kasumi Bashira") {
                loginScreen.style.opacity = "0";
                setTimeout(() => {
                    loginScreen.style.display = "none";
                    mainContent.style.display = "block";
                    setTimeout(() => {
                        mainContent.style.opacity = "1";
                        AOS.init({ duration: 1000, once: true });
                    }, 50);
                }, 500);
            } else {
                errorMsg.style.display = "block";
                document.querySelector('.login-box').style.animation = "shake 0.3s";
                setTimeout(() => { document.querySelector('.login-box').style.animation = ""; }, 300);
            }
        }

        function switchLevel(levelNum) {
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.archive-zone').forEach(zone => zone.classList.remove('active'));

            document.querySelectorAll('.tab-btn')[levelNum - 1].classList.add('active');
            document.getElementById(`level-${levelNum}`).classList.add('active');
        }

        /* EFFET PARTICULES DIGITALES VERTES */
        const canvas = document.getElementById('matrix-particles');
        const ctx = canvas.getContext('2d');
        let w, h, columns;
        const fontSize = 14;
        let drops = [];

        function initCanvas() { 
            w = canvas.width = window.innerWidth; 
            h = canvas.height = window.innerHeight;
            columns = Math.floor(w / fontSize);
            drops = [];
            for (let x = 0; x < columns; x++) drops[x] = 1;
        }

        function drawMatrix() {
            ctx.fillStyle = 'rgba(10, 13, 11, 0.05)';
            ctx.fillRect(0, 0, w, h);
            ctx.fillStyle = '#00ff66';
            ctx.font = fontSize + 'px monospace';

            for (let i = 0; i < drops.length; i++) {
                const text = String.fromCharCode(Math.floor(Math.random() * 128));
                ctx.fillText(text, i * fontSize, drops[i] * fontSize);
                if (drops[i] * fontSize > h && Math.random() > 0.975) drops[i] = 0;
                drops[i]++;
            }
        }

        window.addEventListener('resize', initCanvas);
        initCanvas();
        setInterval(drawMatrix, 35);
    </script>
</body>
</html>
